{
  "name": "cardtracker",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first card collection dashboard backed by a local SQLite database.",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "launcher": "node launcher/server.cjs --dist dist --open",
    "electron:start": "electron .",
    "electron:dist": "electron-builder",
    "package:windows": "electron-builder --win nsis portable --publish never"
  },
  "dependencies": {
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.cardtracker.app",
    "productName": "CardTracker",
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "launcher/server.cjs",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
